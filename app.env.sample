# netbird - app.env.sample
# Copy to app.env and adjust values before starting the stack.

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=${HOSTNAME}
BASE_DOMAIN_NAME=example.com

# Relay shared secret (min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# OIDC / Auth settings (configure with your identity provider)
NETBIRD_AUTH_AUDIENCE=netbird
NETBIRD_AUTH_CLIENT_ID=netbird-client
NETBIRD_AUTH_AUTHORITY=https://example.com
